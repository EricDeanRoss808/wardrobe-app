{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "{\"createdOn\":\"Windows\",\"createdBy\":\"Amplify\",\"createdWith\":\"14.3.0\",\"stackType\":\"function-Lambda\",\"metadata\":{\"whyContinueWithGen1\":\"Prefer not to answer\"}}",
  "Parameters": {
    "CloudWatchRule": {
      "Type": "String",
      "Default": "NONE",
      "Description": " Schedule Expression"
    },
    "deploymentBucketName": {
      "Type": "String"
    },
    "env": {
      "Type": "String"
    },
    "s3Key": {
      "Type": "String"
    },
    "storagewardrobestorageBucketName": {
      "Type": "String",
      "Default": "storagewardrobestorageBucketName"
    },
    "storageusersName": {
      "Type": "String",
      "Default": "storageusersName"
    },
    "storageusersArn": {
      "Type": "String",
      "Default": "storageusersArn"
    },
    "storageusersStreamArn": {
      "Type": "String",
      "Default": "storageusersStreamArn"
    },
    "storagewardrobeItemsName": {
      "Type": "String",
      "Default": "storagewardrobeItemsName"
    },
    "storagewardrobeItemsArn": {
      "Type": "String",
      "Default": "storagewardrobeItemsArn"
    },
    "storagewardrobeItemsStreamArn": {
      "Type": "String",
      "Default": "storagewardrobeItemsStreamArn"
    },
    "storageoutfitsName": {
      "Type": "String",
      "Default": "storageoutfitsName"
    },
    "storageoutfitsArn": {
      "Type": "String",
      "Default": "storageoutfitsArn"
    },
    "storageoutfitsStreamArn": {
      "Type": "String",
      "Default": "storageoutfitsStreamArn"
    },
    "storageswipeHistoryName": {
      "Type": "String",
      "Default": "storageswipeHistoryName"
    },
    "storageswipeHistoryArn": {
      "Type": "String",
      "Default": "storageswipeHistoryArn"
    },
    "storageswipeHistoryStreamArn": {
      "Type": "String",
      "Default": "storageswipeHistoryStreamArn"
    }
  },
  "Conditions": {
    "ShouldNotCreateEnvResources": {
      "Fn::Equals": [
        {
          "Ref": "env"
        },
        "NONE"
      ]
    }
  },
  "Resources": {
    "LambdaFunction": {
      "Type": "AWS::Lambda::Function",
      "Metadata": {
        "aws:asset:path": "./src",
        "aws:asset:property": "Code"
      },
      "Properties": {
        "Code": {
          "S3Bucket": {
            "Ref": "deploymentBucketName"
          },
          "S3Key": {
            "Ref": "s3Key"
          }
        },
        "Handler": "index.handler",
        "FunctionName": {
          "Fn::If": [
            "ShouldNotCreateEnvResources",
            "wardrobeFunction",
            {
              "Fn::Join": [
                "",
                [
                  "wardrobeFunction",
                  "-",
                  {
                    "Ref": "env"
                  }
                ]
              ]
            }
          ]
        },
        "Environment": {
          "Variables": {
            "ENV": {
              "Ref": "env"
            },
            "REGION": {
              "Ref": "AWS::Region"
            },
            "STORAGE_WARDROBESTORAGE_BUCKETNAME": {
              "Ref": "storagewardrobestorageBucketName"
            },
            "STORAGE_USERS_NAME": {
              "Ref": "storageusersName"
            },
            "STORAGE_USERS_ARN": {
              "Ref": "storageusersArn"
            },
            "STORAGE_USERS_STREAMARN": {
              "Ref": "storageusersStreamArn"
            },
            "STORAGE_WARDROBEITEMS_NAME": {
              "Ref": "storagewardrobeItemsName"
            },
            "STORAGE_WARDROBEITEMS_ARN": {
              "Ref": "storagewardrobeItemsArn"
            },
            "STORAGE_WARDROBEITEMS_STREAMARN": {
              "Ref": "storagewardrobeItemsStreamArn"
            },
            "STORAGE_OUTFITS_NAME": {
              "Ref": "storageoutfitsName"
            },
            "STORAGE_OUTFITS_ARN": {
              "Ref": "storageoutfitsArn"
            },
            "STORAGE_OUTFITS_STREAMARN": {
              "Ref": "storageoutfitsStreamArn"
            },
            "STORAGE_SWIPEHISTORY_NAME": {
              "Ref": "storageswipeHistoryName"
            },
            "STORAGE_SWIPEHISTORY_ARN": {
              "Ref": "storageswipeHistoryArn"
            },
            "STORAGE_SWIPEHISTORY_STREAMARN": {
              "Ref": "storageswipeHistoryStreamArn"
            }
          }
        },
        "Role": {
          "Fn::GetAtt": [
            "LambdaExecutionRole",
            "Arn"
          ]
        },
        "Runtime": "nodejs22.x",
        "Layers": [],
        "Timeout": 25
      }
    },
    "LambdaExecutionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": {
          "Fn::If": [
            "ShouldNotCreateEnvResources",
            "wardrobeappLambdaRole02f77d21",
            {
              "Fn::Join": [
                "",
                [
                  "wardrobeappLambdaRole02f77d21",
                  "-",
                  {
                    "Ref": "env"
                  }
                ]
              ]
            }
          ]
        },
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": [
                  "lambda.amazonaws.com"
                ]
              },
              "Action": [
                "sts:AssumeRole"
              ]
            }
          ]
        }
      }
    },
    "lambdaexecutionpolicy": {
      "DependsOn": [
        "LambdaExecutionRole"
      ],
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "PolicyName": "lambda-execution-policy",
        "Roles": [
          {
            "Ref": "LambdaExecutionRole"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": [
                "logs:CreateLogGroup",
                "logs:CreateLogStream",
                "logs:PutLogEvents"
              ],
              "Resource": {
                "Fn::Sub": [
                  "arn:aws:logs:${region}:${account}:log-group:/aws/lambda/${lambda}:log-stream:*",
                  {
                    "region": {
                      "Ref": "AWS::Region"
                    },
                    "account": {
                      "Ref": "AWS::AccountId"
                    },
                    "lambda": {
                      "Ref": "LambdaFunction"
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    },
    "AmplifyResourcesPolicy": {
      "DependsOn": [
        "LambdaExecutionRole"
      ],
      "Type": "AWS::IAM::Policy",
      "Properties": {
        "PolicyName": "amplify-lambda-execution-policy",
        "Roles": [
          {
            "Ref": "LambdaExecutionRole"
          }
        ],
        "PolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Action": "s3:ListBucket",
              "Resource": [
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:aws:s3:::",
                      {
                        "Ref": "storagewardrobestorageBucketName"
                      }
                    ]
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "s3:PutObject",
                "s3:GetObject",
                "s3:DeleteObject"
              ],
              "Resource": [
                {
                  "Fn::Join": [
                    "",
                    [
                      "arn:aws:s3:::",
                      {
                        "Ref": "storagewardrobestorageBucketName"
                      },
                      "/*"
                    ]
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Put*",
                "dynamodb:Create*",
                "dynamodb:BatchWriteItem",
                "dynamodb:PartiQLInsert",
                "dynamodb:Get*",
                "dynamodb:BatchGetItem",
                "dynamodb:List*",
                "dynamodb:Describe*",
                "dynamodb:Scan",
                "dynamodb:Query",
                "dynamodb:PartiQLSelect"
              ],
              "Resource": [
                {
                  "Ref": "storageusersArn"
                },
                {
                  "Fn::Join": [
                    "/",
                    [
                      {
                        "Ref": "storageusersArn"
                      },
                      "index/*"
                    ]
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Put*",
                "dynamodb:Create*",
                "dynamodb:BatchWriteItem",
                "dynamodb:PartiQLInsert",
                "dynamodb:Get*",
                "dynamodb:BatchGetItem",
                "dynamodb:List*",
                "dynamodb:Describe*",
                "dynamodb:Scan",
                "dynamodb:Query",
                "dynamodb:PartiQLSelect",
                "dynamodb:Update*",
                "dynamodb:RestoreTable*",
                "dynamodb:PartiQLUpdate",
                "dynamodb:Delete*",
                "dynamodb:PartiQLDelete"
              ],
              "Resource": [
                {
                  "Ref": "storagewardrobeItemsArn"
                },
                {
                  "Fn::Join": [
                    "/",
                    [
                      {
                        "Ref": "storagewardrobeItemsArn"
                      },
                      "index/*"
                    ]
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Put*",
                "dynamodb:Create*",
                "dynamodb:BatchWriteItem",
                "dynamodb:PartiQLInsert",
                "dynamodb:Get*",
                "dynamodb:BatchGetItem",
                "dynamodb:List*",
                "dynamodb:Describe*",
                "dynamodb:Scan",
                "dynamodb:Query",
                "dynamodb:PartiQLSelect",
                "dynamodb:Update*",
                "dynamodb:RestoreTable*",
                "dynamodb:PartiQLUpdate",
                "dynamodb:Delete*",
                "dynamodb:PartiQLDelete"
              ],
              "Resource": [
                {
                  "Ref": "storageoutfitsArn"
                },
                {
                  "Fn::Join": [
                    "/",
                    [
                      {
                        "Ref": "storageoutfitsArn"
                      },
                      "index/*"
                    ]
                  ]
                }
              ]
            },
            {
              "Effect": "Allow",
              "Action": [
                "dynamodb:Put*",
                "dynamodb:Create*",
                "dynamodb:BatchWriteItem",
                "dynamodb:PartiQLInsert",
                "dynamodb:Get*",
                "dynamodb:BatchGetItem",
                "dynamodb:List*",
                "dynamodb:Describe*",
                "dynamodb:Scan",
                "dynamodb:Query",
                "dynamodb:PartiQLSelect",
                "dynamodb:Update*",
                "dynamodb:RestoreTable*",
                "dynamodb:PartiQLUpdate",
                "dynamodb:Delete*",
                "dynamodb:PartiQLDelete"
              ],
              "Resource": [
                {
                  "Ref": "storageswipeHistoryArn"
                },
                {
                  "Fn::Join": [
                    "/",
                    [
                      {
                        "Ref": "storageswipeHistoryArn"
                      },
                      "index/*"
                    ]
                  ]
                }
              ]
            }
          ]
        }
      }
    }
  },
  "Outputs": {
    "Name": {
      "Value": {
        "Ref": "LambdaFunction"
      }
    },
    "Arn": {
      "Value": {
        "Fn::GetAtt": [
          "LambdaFunction",
          "Arn"
        ]
      }
    },
    "Region": {
      "Value": {
        "Ref": "AWS::Region"
      }
    },
    "LambdaExecutionRole": {
      "Value": {
        "Ref": "LambdaExecutionRole"
      }
    },
    "LambdaExecutionRoleArn": {
      "Value": {
        "Fn::GetAtt": [
          "LambdaExecutionRole",
          "Arn"
        ]
      }
    }
  }
}